{
  "name": "pda-cli",
  "version": "0.1.0",
  "description": "CLI tool for Android PDA development — ADB, Cordova, EasyMobile",
  "type": "module",
  "bin": {
    "pda": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test:cli": "tsx src/index.ts --",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huiitre/pda-cli.git"
  },
  "author": "huiitre",
